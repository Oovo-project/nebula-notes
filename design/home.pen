                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "HnrxD",
                      "name": "footerText",
                      "fill": "#ffffff1a",
                      "content": "Nebula Notes",
                      "fontFamily": "Noto Sans JP",
                      "fontSize": 14,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "hiywR",
                      "name": "footerSub",
                      "fill": "#ffffff14",
                      "content": "声を、星に。思考を、星座に。",
                      "fontFamily": "Noto Sans JP",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
