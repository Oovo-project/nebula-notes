                              "name": "priv3Head",
                              "gap": 10,
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "icon_font",
                                  "id": "GtXlV",
                                  "name": "priv3Icon",
                                  "width": 18,
                                  "height": 18,
                                  "iconFontName": "timer",
                                  "iconFontFamily": "lucide",
                                  "fill": "#8ab4f8ff"
                                },
                                {
                                  "type": "text",
                                  "id": "7NQ26",
                                  "name": "priv3Title",
                                  "fill": "#ffffffff",
                                  "content": "120秒制限",
                                  "fontFamily": "Noto Sans JP",
                                  "fontSize": 15,
                                  "fontWeight": "700"
                                }
                              ]
                            },
                            {
                              "type": "text",
                              "id": "ZA3Qm",
                              "name": "priv3Desc",
                              "fill": "#6b7280ff",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "1回の録音は最大120秒。短く区切ることで要約の精度が向上し、思考の粒度を保ちます。超過時は自動的に録音が停止されます。",
                              "lineHeight": 1.8,
                              "fontFamily": "Noto Sans JP",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "rectangle",
                  "id": "tH399",
                  "name": "Divider",
                  "fill": "#ffffff0d",
                  "width": "fill_container",
                  "height": 1
                },
                {
                  "type": "frame",
                  "id": "QmPi0",
                  "name": "Footer",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 8,
                  "padding": [
