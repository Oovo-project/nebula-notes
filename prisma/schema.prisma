generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Memo {
  id         String   @id @default(cuid())
  title      String
  summary    String
  transcript String?
  audioPath  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
